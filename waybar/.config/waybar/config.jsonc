  },

  "custom/launcher": {
    "format": "َ°£‡ MENU",
    "on-click": "~/.config/rofi/crt/launcher.sh",
  },

  "custom/title": {
    "return-type": "json",
    "interval": 1,
    "exec": "~/.config/waybar/scripts/title.sh",
  },

  "cpu": { "format": "ï’¼ {usage}%", "interval": 500 },
  "memory": { "format": "î؟… {percentage}%", "interval": 500 },

  "pulseaudio": {
    "format": " َ±„  {volume}%",
    "on-click": "pavucontrol",
  },

  "custom/updates": {
    "interval": 1800,
    "exec": "checkupdates | wc -l",
    "format": "َ°ڑ° {}",
  },

  "clock": {
    "format": "{:%I:%M %p}",
    "tooltip-format": "<tt>{calendar}</tt>",
  },

  "custom/power": {
    "format": "âڈ»",
    "on-click": "quickshell -p ~/.config/quickshell/snes-hub/bar/PowerMenu.qml",
  },

  "tray": { "icon-size": 16, "spacing": 8 },
}
